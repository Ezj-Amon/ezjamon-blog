---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconSearch from "@/assets/icons/IconSearch.svg";
import type { TaxonomyGroup } from "@/utils/getContentTaxonomy";
import config from "@/config";

type Props = {
  label: string;
  collectionPath: string;
  taxonomy: TaxonomyGroup[];
  sortLabel: string;
  searchLabel?: string;
};

const {
  label,
  collectionPath,
  taxonomy,
  sortLabel,
  searchLabel = "搜索",
} = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<nav
  aria-label={label}
  class="border-border bg-muted/45 mb-6 rounded-lg border p-3"
>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
      <a
        href={getRelativeLocaleUrl(locale, collectionPath)}
        class="bg-accent text-accent-foreground rounded-md px-3 py-1.5 text-sm font-semibold"
      >
        全部
      </a>
      {
        taxonomy.slice(0, 5).map(group => (
          <a
            href={getRelativeLocaleUrl(locale, `categories/${group.category}/`)}
            class="border-border bg-background hover:border-accent hover:text-accent rounded-md border px-3 py-1.5 text-sm font-semibold transition"
          >
            {group.categoryName}
            <span class="text-muted-foreground ms-1 text-xs">
              {group.count}
            </span>
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <span
        class="text-muted-foreground px-1 py-1.5 text-xs font-semibold sm:text-sm"
        aria-label={`当前排序：${sortLabel}`}
      >
        {sortLabel}
      </span>
      {
        config.features.search !== false && (
          <a
            href={getRelativeLocaleUrl(locale, "search")}
            class="border-border bg-background hover:border-accent hover:text-accent inline-flex size-8 items-center justify-center rounded-md border transition"
            aria-label={searchLabel}
            title={searchLabel}
          >
            <IconSearch class="size-4" />
          </a>
        )
      }
    </div>
  </div>
</nav>
