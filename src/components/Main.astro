---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  pageTitle: string | [string, string];
  pageDesc?: string;
  class?: string;
  pagefindBody?: boolean;
  wide?: boolean;
};

const {
  pageTitle,
  pageDesc,
  class: className,
  pagefindBody = true,
  wide = false,
} = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const backUrl = config.features.showBackButton
  ? Astro.url.pathname
  : getRelativeLocaleUrl(locale, "");
---

<main
  data-backUrl={backUrl}
  data-pagefind-body={pagefindBody ? "" : undefined}
  id="main-content"
  class:list={[
    "app-layout border-border bg-background border-x border-b px-5 pt-5 pb-8 shadow-[0_24px_55px_rgba(15,23,42,0.07)] sm:px-8 sm:pt-7 sm:pb-10",
    wide ? "" : "max-w-app",
    className,
  ]}
>
  <h1 class="text-3xl leading-none font-bold tracking-[-0.01em] sm:text-4xl">
    {pageTitle}
  </h1>
  <p class="text-muted-foreground mt-2 mb-6 text-sm font-medium">
    {pageDesc}
  </p>
  <slot />
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>
