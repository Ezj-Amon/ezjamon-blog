---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  count?: number;
  size?: "sm" | "lg";
};

const { tag, tagName, count, size = "lg" } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "bg-muted hover:text-accent flex items-center gap-1 rounded-md px-3 py-1.5 font-semibold transition",
      "focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <span>{tagName}</span>
    {
      count !== undefined && (
        <span class="text-muted-foreground ml-1 text-xs tabular-nums">
          {count}
        </span>
      )
    }
  </a>
</li>
