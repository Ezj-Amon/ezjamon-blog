---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import { getContentTaxonomy, getEntryCategory, getEntrySecondaryTags } from "@/utils/getContentTaxonomy";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { resourceTypeLabels } from "@/utils/resourceTypeLabels";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts");
const resources = (
  await getCollection("resources", ({ data }) => !data.draft)
).sort(
  (a, b) =>
    new Date(b.data.pubDatetime).getTime() -
    new Date(a.data.pubDatetime).getTime()
);
const progressItems = (
  await getCollection("progress", ({ data }) => !data.draft)
)
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  )
  .slice(0, 4);
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const curatedPosts =
  featuredPosts.length >= 2 ? featuredPosts.slice(0, 2) : sortedPosts.slice(0, 2);
const latestPosts = sortedPosts.slice(0, 4);
const tags = getUniqueTags([...sortedPosts, ...resources]).slice(0, 16);
const taxonomy = getContentTaxonomy([...sortedPosts, ...resources]);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout border-border bg-background border-x border-b px-5 pt-7 pb-8 shadow-[0_24px_55px_rgba(15,23,42,0.07)] sm:px-8 sm:pt-8 sm:pb-10"
  >
    <section
      id="hero"
      class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-center"
    >
      <div>
        <p class="text-accent text-sm font-semibold">
          你好，欢迎来到我的数字花园 👋
        </p>
        <h1
          class="mt-3 max-w-3xl text-4xl leading-[1.05] font-black tracking-[-0.01em] text-slate-950 sm:text-5xl lg:text-6xl"
        >
          Amon's Notes<br />
          一些正在生长的记录。
        </h1>
        <p class="text-muted-foreground mt-4 max-w-2xl text-base leading-7">
          这里存放文章、工具、链接和阶段性的思考。它们不一定完整，但会随着使用和复盘慢慢变得清晰。
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-3">
          <LinkButton
            href={getRelativeLocaleUrl(locale, "posts")}
            class="bg-accent text-accent-foreground hover:text-accent-foreground rounded-md px-5 py-3 text-sm font-semibold shadow-sm"
          >
            浏览文章
            <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
          </LinkButton>
          <LinkButton
            href={getRelativeLocaleUrl(locale, "resources")}
            class="border-border hover:border-accent hover:text-accent rounded-md border px-5 py-3 text-sm font-semibold"
          >
            查看收藏
          </LinkButton>
          <LinkButton
            target="_blank"
            href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
            class="border-border hover:border-accent hover:text-accent rounded-md border p-3"
            aria-label="RSS 订阅"
            title="RSS 订阅"
          >
            <IconRss class="size-5 stroke-3" />
            <span class="sr-only">RSS 订阅</span>
          </LinkButton>
        </div>
      </div>

      <aside
        class="border-border bg-background overflow-hidden rounded-xl border shadow-[0_18px_36px_rgba(15,23,42,0.06)]"
      >
        <div class="p-5">
          <h2 class="flex items-center gap-2 text-lg font-bold">
            <span class="bg-accent/10 text-accent rounded-md px-2 py-1 text-sm">
              ↗
            </span>
            最近在折腾
          </h2>
          <ul class="mt-5 space-y-4">
            {
              progressItems.map(item => (
                <li class="flex items-center gap-4 text-sm font-medium">
                  <span class="bg-accent size-1.5 rounded-full" />
                  <a
                    href={getRelativeLocaleUrl(
                      locale,
                      `progress/${item.id}/`
                    )}
                    class="hover:text-accent"
                  >
                    {item.data.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <a
          href={getRelativeLocaleUrl(locale, "progress")}
          class="border-border text-accent hover:bg-muted flex items-center justify-center gap-2 border-t px-5 py-4 text-sm font-semibold"
        >
          查看全部进展
          <IconArrowRight class="size-4 rtl:-rotate-180" />
        </a>
      </aside>
    </section>

    <section class="mt-7 grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem]">
      <div>
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="text-2xl font-bold">精选文章</h2>
          <a
            href={getRelativeLocaleUrl(locale, "posts")}
            class="text-accent inline-flex items-center gap-2 text-sm font-semibold"
          >
            查看更多
            <IconArrowRight class="size-4 rtl:-rotate-180" />
          </a>
        </div>
        <ul class="grid gap-4 sm:grid-cols-2">
          {curatedPosts.map(post => <Card variant="h3" {...post} />)}
        </ul>
      </div>

      <aside class="border-border lg:border-l lg:pl-8">
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="text-2xl font-bold">最新文章</h2>
          <a
            href={getRelativeLocaleUrl(locale, "posts")}
            class="text-accent inline-flex items-center gap-2 text-sm font-semibold"
          >
            查看更多
            <IconArrowRight class="size-4 rtl:-rotate-180" />
          </a>
        </div>
        <ul class="space-y-5">
          {
            latestPosts.map(post => (
              <li class="grid grid-cols-[0.4rem_minmax(0,1fr)] gap-4">
                <span class="bg-accent mt-2 size-1.5 rounded-full" />
                <div>
                  <a
                    href={getPostUrl(post.id, post.filePath, locale)}
                    class="hover:text-accent line-clamp-2 text-sm font-semibold"
                  >
                    {post.data.title}
                  </a>
                  <Datetime
                    class="mt-1 text-xs [&>svg]:hidden [&_time]:text-xs"
                    pubDatetime={post.data.pubDatetime}
                    modDatetime={post.data.modDatetime}
                  />
                </div>
              </li>
            ))
          }
        </ul>
      </aside>
    </section>

    <section class="mt-6">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-2xl font-bold">最近收藏</h2>
        <div class="hidden items-center gap-2 sm:flex">
          <button
            type="button"
            data-resource-scroll="prev"
            class="border-border hover:border-accent hover:text-accent grid size-8 place-items-center rounded-md border"
            aria-label="上一组收藏"
          >
            <IconChevronLeft class="size-4" />
          </button>
          <button
            type="button"
            data-resource-scroll="next"
            class="border-border hover:border-accent hover:text-accent grid size-8 place-items-center rounded-md border"
            aria-label="下一组收藏"
          >
            <IconChevronLeft class="size-4 rotate-180" />
          </button>
        </div>
      </div>
      <ul
        data-resource-strip
        class="flex snap-x gap-4 overflow-x-auto scroll-smooth pb-1"
      >
        {
          resources.slice(0, 8).map(resource => {
            const category = getEntryCategory(resource);
            const secondaryTags = getEntrySecondaryTags(resource).slice(0, 3);

            return (
              <li class="min-w-[calc(100%-0.25rem)] snap-start sm:min-w-[calc((100%-2rem)/3)]">
                <article class="border-border bg-background flex h-full flex-col rounded-lg border p-3 transition hover:border-accent/70 hover:shadow-lg hover:shadow-black/5">
                  <div class="mb-3 flex items-center gap-2 text-xs font-semibold">
                    <span class="bg-accent/10 text-accent rounded-md px-2 py-1">
                      ◴
                    </span>
                    <a
                      href={getRelativeLocaleUrl(
                        locale,
                        `categories/${category.category}/`
                      )}
                      class="bg-muted rounded-md px-2 py-1"
                    >
                      {category.categoryName}
                    </a>
                    <span class="bg-muted rounded-md px-2 py-1">
                      {resourceTypeLabels[resource.data.type]}
                    </span>
                  </div>
                  <a
                    href={resource.data.url}
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-accent line-clamp-2 text-base font-bold leading-snug"
                  >
                    {resource.data.title}
                  </a>
                  <p class="text-muted-foreground mt-1 line-clamp-1 text-sm leading-6">
                    {resource.data.description}
                  </p>
                  {resource.data.source && (
                    <p class="text-muted-foreground mt-2 text-xs">
                      来源：{resource.data.source}
                    </p>
                  )}
                  {secondaryTags.length > 0 && (
                    <ul class="mt-auto flex flex-wrap gap-2 pt-3">
                      {secondaryTags.map(tag => (
                        <Tag
                          tag={tag.tag}
                          tagName={tag.tagName}
                          size="sm"
                        />
                      ))}
                    </ul>
                  )}
                  <Datetime
                    class="mt-3 text-xs [&>svg]:hidden [&_time]:text-xs"
                    pubDatetime={resource.data.pubDatetime}
                  />
                </article>
              </li>
            );
          })
        }
      </ul>
    </section>

    <section class="mt-6">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-2xl font-bold">常用标签</h2>
        <a
          href={getRelativeLocaleUrl(locale, "tags")}
          class="text-accent inline-flex items-center gap-2 text-sm font-semibold"
        >
          查看更多
          <IconArrowRight class="size-4 rtl:-rotate-180" />
        </a>
      </div>
      <ul class="flex flex-wrap gap-2">
        {
          tags.map(({ tag, tagName, count }) => (
            <Tag {tag} {tagName} {count} size="sm" />
          ))
        }
        {taxonomy.length > 0 && (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, "tags")}
              class="bg-muted hover:text-accent inline-flex rounded-md px-4 py-1.5 text-sm font-semibold"
            >
              更多..
            </a>
          </li>
        )}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    const strip = document.querySelector<HTMLElement>("[data-resource-strip]");
    const buttons =
      document.querySelectorAll<HTMLButtonElement>("[data-resource-scroll]");

    buttons.forEach(button => {
      button.addEventListener("click", () => {
        if (!strip) return;
        const direction = button.dataset.resourceScroll === "prev" ? -1 : 1;
        strip.scrollBy({
          left: direction * Math.max(280, strip.clientWidth / 3),
          behavior: "smooth",
        });
      });
    });
  });
</script>
