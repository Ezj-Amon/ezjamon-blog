---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Datetime from "@/components/Datetime.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import Tag from "@/components/Tag.astro";
import {
  entryHasCategory,
  getContentTaxonomy,
} from "@/utils/getContentTaxonomy";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import { postFilter } from "@/utils/postFilter";
import { resourceTypeLabels } from "@/utils/resourceTypeLabels";
import config from "@/config";

type CategoryPageItem = {
  title: string;
  description: string;
  href: string;
  pubDatetime: Date;
  modDatetime?: Date | null;
  label: string;
  source?: string;
  external?: boolean;
};

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = getSortedPosts(await getCollection("posts", postFilter));
  const resources = (
    await getCollection("resources", ({ data }) => !data.draft)
  ).sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  );
  const entries = [...posts, ...resources];
  const taxonomy = getContentTaxonomy(entries);

  return taxonomy.flatMap(group => {
    const categoryItems: CategoryPageItem[] = [
      ...posts
        .filter(post => entryHasCategory(post, group.category))
        .map(post => ({
          title: post.data.title,
          description: post.data.description,
          href: getPostUrl(post.id, post.filePath, config.site.lang),
          pubDatetime: post.data.pubDatetime,
          modDatetime: post.data.modDatetime,
          label: "文章",
        })),
      ...resources
        .filter(resource => entryHasCategory(resource, group.category))
        .map(resource => ({
          title: resource.data.title,
          description: resource.data.description,
          href: resource.data.url,
          pubDatetime: resource.data.pubDatetime,
          modDatetime: undefined,
          label: resourceTypeLabels[resource.data.type],
          source: resource.data.source,
          external: true,
        })),
    ].sort(
      (a, b) =>
        new Date(b.modDatetime ?? b.pubDatetime).getTime() -
        new Date(a.modDatetime ?? a.pubDatetime).getTime()
    );

    return paginate(categoryItems, {
      params: { category: group.category },
      props: {
        categoryName: group.categoryName,
        categoryTags: group.tags,
      },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, categoryName, categoryTags } = Astro.props;
---

<Layout title={`分类: ${categoryName} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle={`分类: ${categoryName}`}
    pageDesc={`共 ${page.total} 条内容。`}
    wide
  >
    {
      categoryTags.length > 0 && (
        <ul class="border-border mb-8 flex flex-wrap gap-2 border-b pb-6">
          {categoryTags.map(tag => (
            <Tag
              tag={tag.tag}
              tagName={tag.tagName}
              count={tag.count}
              size="sm"
            />
          ))}
        </ul>
      )
    }

    <ul class="grid gap-4 md:grid-cols-2">
      {
        page.data.map(item => (
          <li>
            <article class="border-border bg-background hover:border-accent/70 flex h-full flex-col rounded-lg border p-5 transition hover:-translate-y-0.5">
              <div class="text-muted-foreground mb-4 flex flex-wrap items-center gap-2 text-sm">
                <span class="bg-accent text-accent-foreground rounded-md px-2 py-1 text-xs font-semibold">
                  {item.label}
                </span>
                {item.source && <span>{item.source}</span>}
              </div>

              <a
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer" : undefined}
                class="group rounded-sm"
              >
                <h2 class="group-hover:text-accent text-xl leading-snug font-semibold">
                  {item.title}
                </h2>
              </a>
              <Datetime
                class="mt-3"
                pubDatetime={item.pubDatetime}
                modDatetime={item.modDatetime}
              />
              <p class="text-muted-foreground mt-3 line-clamp-3 leading-7">
                {item.description}
              </p>
            </article>
          </li>
        ))
      }
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
