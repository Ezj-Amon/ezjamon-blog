---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import CollectionNav from "@/components/CollectionNav.astro";
import {
  getContentTaxonomy,
  getEntryCategory,
  getEntrySecondaryTags,
} from "@/utils/getContentTaxonomy";
import { resourceTypeLabels } from "@/utils/resourceTypeLabels";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const resources = (
  await getCollection("resources", ({ data }) => !data.draft)
).sort(
  (a, b) =>
    new Date(b.data.pubDatetime).getTime() -
    new Date(a.data.pubDatetime).getTime()
);
const taxonomy = getContentTaxonomy(resources);
---

<Layout title={`${t.pages.resourcesTitle} | ${config.site.title}`}>
  <Header />

  <Main
    pageTitle={t.pages.resourcesTitle}
    pageDesc={t.pages.resourcesDesc}
    wide
  >
    <CollectionNav
      label="收藏分类"
      collectionPath="resources"
      {taxonomy}
      sortLabel="最新收藏"
      searchLabel="搜索收藏"
    />

    <ul class="grid gap-4 sm:grid-cols-3">
      {
        resources.map(resource => {
          const { data } = resource;
          const category = getEntryCategory(resource);
          const secondaryTags = getEntrySecondaryTags(resource).slice(0, 3);

          return (
            <li>
              <article class="border-border bg-background hover:border-accent/70 flex h-full min-h-56 flex-col rounded-lg border p-4 transition hover:shadow-lg hover:shadow-black/5">
                <div class="mb-3 flex flex-wrap items-center gap-2 text-xs font-semibold">
                  <span
                    class="bg-accent/10 text-accent rounded-md px-2 py-1"
                    aria-hidden="true"
                  >
                    ◴
                  </span>
                  <a
                    href={getRelativeLocaleUrl(
                      locale,
                      `categories/${category.category}/`
                    )}
                    class="bg-muted rounded-md px-2 py-1"
                  >
                    {category.categoryName}
                  </a>
                  <span class="bg-muted rounded-md px-2 py-1">
                    {resourceTypeLabels[data.type]}
                  </span>
                </div>

                <a
                  href={data.url}
                  target="_blank"
                  rel="noreferrer"
                  class="hover:text-accent line-clamp-2 text-lg leading-snug font-bold"
                >
                  {data.title}
                </a>

                {data.note ? (
                  <p class="text-muted-foreground mt-2 line-clamp-3 text-sm leading-6">
                    记：{data.note}
                  </p>
                ) : (
                  <p class="text-muted-foreground mt-2 line-clamp-3 text-sm leading-6">
                    {data.description}
                  </p>
                )}

                {data.source && (
                  <p class="text-muted-foreground mt-3 text-sm">
                    来源：{data.source}
                  </p>
                )}

                {secondaryTags.length > 0 && (
                  <ul class="mt-auto flex flex-wrap gap-2 pt-4">
                    {secondaryTags.map(tag => (
                      <Tag tag={tag.tag} tagName={tag.tagName} size="sm" />
                    ))}
                  </ul>
                )}

                <div class="mt-4 flex items-center justify-between gap-3">
                  <Datetime
                    class="text-xs [&_time]:text-xs [&>svg]:hidden"
                    pubDatetime={data.pubDatetime}
                  />
                  <a
                    href={data.url}
                    target="_blank"
                    rel="noreferrer"
                    class="text-accent text-xs font-semibold"
                    aria-label={`打开收藏：${data.title}`}
                  >
                    打开
                  </a>
                </div>
              </article>
            </li>
          );
        })
      }
    </ul>

    {
      resources.length === 0 && (
        <p class="text-muted-foreground">还没有收藏内容。</p>
      )
    }
  </Main>

  <Footer />
</Layout>
