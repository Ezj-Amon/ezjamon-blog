---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const typeLabels = {
  article: "文章",
  video: "视频",
  course: "教程",
  tool: "工具",
  bookmark: "收藏",
  repo: "代码",
  game: "游戏",
};

const resources = (
  await getCollection("resources", ({ data }) => !data.draft)
).sort(
  (a, b) =>
    new Date(b.data.pubDatetime).getTime() -
    new Date(a.data.pubDatetime).getTime()
);
---

<Layout title={`${t.pages.resourcesTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.resourcesTitle} pageDesc={t.pages.resourcesDesc}>
    <ul class="space-y-5">
      {
        resources.map(({ data }) => (
          <li class="border-border rounded-md border p-4">
            <div class="flex flex-wrap items-center gap-2">
              <span class="bg-muted text-muted-foreground rounded px-2 py-0.5 text-xs font-medium">
                {typeLabels[data.type]}
              </span>
              {data.source && (
                <span class="text-muted-foreground text-sm">{data.source}</span>
              )}
            </div>

            <h2 class="mt-3 text-xl font-semibold">
              <a
                href={data.url}
                target="_blank"
                rel="noreferrer"
                class="hover:text-accent decoration-dashed underline-offset-4 hover:underline"
              >
                {data.title}
              </a>
            </h2>

            <p class="text-muted-foreground mt-2 leading-7">
              {data.description}
            </p>

            {data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {data.tags.map(tag => (
                  <span class="border-border text-muted-foreground rounded border px-2 py-0.5 text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ul>

    {
      resources.length === 0 && (
        <p class="text-muted-foreground">还没有收藏内容。</p>
      )
    }
  </Main>

  <Footer />
</Layout>
