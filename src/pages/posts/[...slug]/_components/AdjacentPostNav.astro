---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getPostUrl } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
} | null;

type Props = {
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<div data-pagefind-ignore class="my-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
  {
    prevPost && (
      <a
        href={getPostUrl(prevPost.id, prevPost.filePath, locale)}
        class="border-border bg-muted/45 hover:border-accent hover:text-accent flex w-full gap-3 rounded-lg border p-4 transition"
      >
        <IconArrowLeft class="inline-block flex-none rtl:rotate-180" />
        <div>
          <span class="text-muted-foreground text-xs font-semibold">
            {t.post.previousPost}
          </span>
          <div class="mt-1 line-clamp-2 text-sm font-bold">
            {prevPost.title}
          </div>
        </div>
      </a>
    )
  }
  {
    nextPost && (
      <a
        href={getPostUrl(nextPost.id, nextPost.filePath, locale)}
        class="border-border bg-muted/45 hover:border-accent hover:text-accent flex w-full justify-end gap-3 rounded-lg border p-4 text-end transition sm:col-start-2"
      >
        <div>
          <span class="text-muted-foreground text-xs font-semibold">
            {t.post.nextPost}
          </span>
          <div class="mt-1 line-clamp-2 text-sm font-bold">
            {nextPost.title}
          </div>
        </div>
        <IconArrowRight class="inline-block flex-none rtl:rotate-180" />
      </a>
    )
  }
</div>
